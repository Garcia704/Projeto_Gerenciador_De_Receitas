                    char conteudo_receita[50][255];     // Matriz para carregar o corpo da receita na memória
                    FILE *arquivo_editar = fopen(FILE_NAME, "r");
                    if (!arquivo_editar) {
                        printf(VERMELHO"\nErro: Arquivo nao encontrado ou vazio."RESET);
                        getch();
                        break;
                    }
                    
                    char lista_nomes_receitas[50][100];
                    char etiqueta_alvo[110];
                    char metadados_antigos[255];
                    int escolha_do_usuario;
                    int total_receitas_carregadas = 0;
                    int validando = 1;
                    do{
                        FILE *arquivo_editar = fopen(FILE_NAME, "r");
                        if (!arquivo_editar) {
                        printf(VERMELHO"\nErro: Arquivo nao encontrado ou vazio."RESET);
                        getch();
                        break;
                    }
                    total_receitas_carregadas = 0;
                    validando = 1;
                    
                    // --- 1. LISTAGEM DAS RECEITAS ---
                    printf(MAGENTA NEGRITO"\n--- Selecione a Receita para Editar ---\n"RESET);
                    while (fgets(linha_leitura, sizeof(linha_leitura), arquivo_editar)) {
                        if (linha_leitura[0] == '[' && !strstr(linha_leitura, "[TERMINO]")) {
                            char nome_temporario[100]; 
                            strcpy(nome_temporario, linha_leitura + 1); 
                            nome_temporario[strcspn(nome_temporario, "]\n")] = 0;
                            
                            strcpy(lista_nomes_receitas[total_receitas_carregadas++], nome_temporario); 
                            printf(CIANO NEGRITO"[%d]"RESET""NEGRITO" %s\n"RESET, total_receitas_carregadas, lista_nomes_receitas[total_receitas_carregadas-1]);
                        }
                    }
                    fclose(arquivo_editar);
                    
                    if (total_receitas_carregadas == 0) {
                        printf(VERMELHO"\nNenhuma receita encontrada."RESET);
                        getch();
                        break;
                    }
                    
                    printf(NEGRITO"\nNumero "RESET""VERMELHO NEGRITO"(0 para cancelar): "RESET); 
                    scanf("%d", &escolha_do_usuario); 
                    while(getchar() != '\n'); // Limpa buffer
                        if((escolha_do_usuario > total_receitas_carregadas) || (escolha_do_usuario < 0)){
                            system("cls");
                            cabecalho();
                            printf(VERMELHO"\nERRO. Escolha não existente ou escolha negativa.\n"RESET);
                        }else{
                            validando = 0;
                        }
                        
                    }while(validando == 1);
                    if(escolha_do_usuario == 0){
                        break;
                    }
                    sprintf(etiqueta_alvo, "[%s]", lista_nomes_receitas[escolha_do_usuario-1]);

                    // --- 2. RECUPERAÇÃO DE METADADOS (CATEGORIA/TEMPO) ---
                    arquivo_editar = fopen(FILE_NAME, "r");
                    while(fgets(linha_leitura, sizeof(linha_leitura), arquivo_editar)) {
                        char tL[110]; 
                        strcpy(tL, linha_leitura); 
                        tL[strcspn(tL, "\n")] = 0;
                        
                        if(strcmp(tL, etiqueta_alvo) == 0) { 
                            fgets(metadados_antigos, sizeof(metadados_antigos), arquivo_editar); 
                            break; 
                        }
                    }
                    fclose(arquivo_editar);
                    system("cls");
                    cabecalho();
                    // --- 3. EDIÇÃO DO NOME ---
                    printf(NEGRITO"\nNovo Nome (Deixe vazio para manter): "RESET);
                    fgets(titulo_receita, 100, stdin);
                    titulo_receita[strcspn(titulo_receita, "\n")] = 0;
                    
                    if(strlen(titulo_receita) == 0) {
                        strcpy(titulo_receita, lista_nomes_receitas[escolha_do_usuario-1]);
                    }

                    // --- 4. EDIÇÃO DAS CATEGORIAS ---
                    printf(NEGRITO"Novas Categorias (Deixe vazio para manter): "RESET);
                    fgets(categoria_receita, 100, stdin);
                    categoria_receita[strcspn(categoria_receita, "\n")] = 0;
                    
                    if(strlen(categoria_receita) == 0) {
                        char mC[255]; 
                        strcpy(mC, metadados_antigos + 5); // Pula o prefixo "META|"
                        char *token_categoria = strtok(mC, "|"); 
                        if(token_categoria) strcpy(categoria_receita, token_categoria);
                    } else {
                        // Formata espaços para vírgulas
                        for(int i = 0; categoria_receita[i]; i++) {
                            if(categoria_receita[i] == ' ') categoria_receita[i] = ',';
                        }
                    }

                    // --- 5. EDIÇÃO DO TEMPO DE PREPARO ---
                    char confirma_alteracao_tempo[10]; 
                    printf(NEGRITO"Alterar tempo de preparo? (S/N): "RESET); 
                    fgets(confirma_alteracao_tempo, 10, stdin);
                    
                    if (toupper(confirma_alteracao_tempo[0]) == 'S') {
                        char tempo_bruto_editado[100]; 
                        int novas_horas = 0, novos_minutos = 0;
                        
                        printf(NEGRITO"Novo tempo (Ex: 1h 30min): "RESET); 
                        fgets(tempo_bruto_editado, 100, stdin);
                        
                        for(int i = 0; tempo_bruto_editado[i]; i++) {
                            tempo_bruto_editado[i] = tolower(tempo_bruto_editado[i]);
                        }
                        
                        char *ponteiro_h = strstr(tempo_bruto_editado, "h");
                        char *ponteiro_m = strstr(tempo_bruto_editado, "m");
                        
                        if(ponteiro_h) { 
                            char *aux = ponteiro_h - 1; 
                            while(aux >= tempo_bruto_editado && isdigit(*aux)) aux--; 
                            novas_horas = atoi(aux + 1); 
                        }
                        if(ponteiro_m) { 
                            char *aux_2 = ponteiro_m - 1; 
                            while(aux_2 >= tempo_bruto_editado && isdigit(*aux_2)) aux_2--; 
                            novos_minutos = atoi(aux_2 + 1); 
                        }
                        int totalMin = novas_horas * 60 + novos_minutos;

                        sprintf(
                        tempo_final_preparo,
                        "Tempo total em minutos: %dmin | Tempo de preparo: %dh %dmin", totalMin, novas_horas, novos_minutos);
                        } else { 
                        // Resgata o tempo original da string META
                        char *ptr_separador = strrchr(metadados_antigos, '|'); 
                        if(ptr_separador) { 
                            strcpy(tempo_final_preparo, ptr_separador + 1); 
                            tempo_final_preparo[strcspn(tempo_final_preparo, "\n")] = 0; 
                        } 
                    }

                    // --- 6. CARREGAMENTO DO CONTEÚDO PARA MEMÓRIA ---
                    int limite_de_edicao = 0; 
                    for(int i = 0; i < 50; i++) {
                        memset(conteudo_receita[i], 0, 255);
                    }
                    
                    arquivo_editar = fopen(FILE_NAME, "r");
                    while(fgets(linha_leitura, sizeof(linha_leitura), arquivo_editar)) {
                        char tL[110]; 
                        strcpy(tL, linha_leitura); 
                        tL[strcspn(tL, "\n")] = 0;
                        
                        if(strcmp(tL, etiqueta_alvo) == 0) {
                            fgets(linha_leitura, 255, arquivo_editar); // Pula linha META
                            while(fgets(linha_leitura, 255, arquivo_editar) && !strstr(linha_leitura, "[TERMINO]")) {
                                linha_leitura[strcspn(linha_leitura, "\n")] = 0; 
                                strcpy(conteudo_receita[limite_de_edicao++], linha_leitura);
                            }
                            break;
                        }
                    }
                    fclose(arquivo_editar);

                    // --- 7. MODO EDITOR INTERATIVO (SETAS / ESC) ---
                    system("cls");
                    cabecalho();
                    printf(MAGENTA NEGRITO"=== EDITANDO CONTEUDO: %s ===\n"RESET, lista_nomes_receitas[escolha_do_usuario-1]);
                    SetConsoleCP(1252);
                    SetConsoleOutputCP(1252);
                    printf(MAGENTA NEGRITO"Use as SETAS para navegar | Pressione ESC para finalizar\n\n"RESET);
                    
                    // Exibe o texto carregado
                    for(int i = 0; i < limite_de_edicao; i++) {
                        printf("%s\n", conteudo_receita[i]);
                    }
                    // Reposiciona o cursor no topo do texto
                    for(int i = 0; i < limite_de_edicao; i++) {
                        printf("\033[A"); 
                    }

                    int cursor_l = 0, cursor_c = 0;
                    unsigned char tecla;
                    // Ajuste para o índice da matriz
                    limite_de_edicao = (limite_de_edicao > 0) ? limite_de_edicao - 1 : 0;

                    while ((tecla = getch()) != 27) { // 27 = ESC
                        if (tecla == 0 || (unsigned char)tecla == 224) {
                            char seta = getch();
                            switch(seta) {
                                case 72: // CIMA
                                    if (cursor_l > 0) {
                                        cursor_l--; 
                                        printf("\033[A"); 
                                        int t = strlen(conteudo_receita[cursor_l]);
                                        if (cursor_c > t) cursor_c = t;
                                        printf("\r");
                                        for(int i=0; i<cursor_c; i++) printf("\033[C");
                                    }
                                    break;
                                case 80: // BAIXO
                                    if (cursor_l < 49 && cursor_l <= limite_de_edicao) {
                                        cursor_l++; 
                                        printf("\033[B"); 
                                        int t = strlen(conteudo_receita[cursor_l]);
                                        if (cursor_c > t) cursor_c = t;
                                        printf("\r");
                                        for(int i=0; i<cursor_c; i++) printf("\033[C");
                                        if(cursor_l > limite_de_edicao) limite_de_edicao = cursor_l;
                                    }
                                    break;
                                case 75: // ESQUERDA
                                    if (cursor_c > 0) { 
                                        cursor_c--; 
                                        printf("\033[D"); 
                                    }
                                    break;
                                case 77: // DIREITA
                                    if (cursor_c < (int)strlen(conteudo_receita[cursor_l])) { 
                                        cursor_c++; 
                                        printf("\033[C"); 
                                    }
                                    break;
                            }
                        } 
                        else if (tecla == 13) { // ENTER
                            if (cursor_l < 49) {
                                cursor_l++; 
                                cursor_c = 0; 
                                printf("\n");
                                if(cursor_l > limite_de_edicao) limite_de_edicao = cursor_l;
                            }
                        } 
                        else if (tecla == 8) { // BACKSPACE
                            if (cursor_c > 0) {
                                int t = strlen(conteudo_receita[cursor_l]);
                                for (int i = cursor_c - 1; i < t; i++) {
                                    conteudo_receita[cursor_l][i] = conteudo_receita[cursor_l][i+1];
                                }
                                cursor_c--;
                                printf("\b\033[s%s \033[u", &conteudo_receita[cursor_l][cursor_c]); 
                            } else if (cursor_l > 0) {
                                cursor_l--;
                                cursor_c = strlen(conteudo_receita[cursor_l]);
                                printf("\033[A\r");
                                for (int i = 0; i < cursor_c; i++) printf("\033[C");
                            }
                        } else if (tecla >= 32) 
                        { // 32 é o espaço, qualquer coisa acima disso é caractere ou acento
                        int t = strlen(conteudo_receita[cursor_l]);
                        if (t < 254) {
                           for (int i = t; i > cursor_c; i--) {
                             conteudo_receita[cursor_l][i] = conteudo_receita[cursor_l][i-1];
                            }
                                conteudo_receita[cursor_l][cursor_c] = (char)tecla;
                                printf("\033[s%s\033[u\033[C", &conteudo_receita[cursor_l][cursor_c]); 
                                cursor_c++;
                            }
                        }
                    }

                    // --- 8. GRAVAÇÃO FINAL ---
                    SetConsoleCP(65001);
                    SetConsoleOutputCP(65001);
                    system("cls");
                    cabecalho();
                    char ativar;
                    int validar = 1;
                    while (validar == 1) 
                        {
                            
                            printf(NEGRITO"\n\nConfirmar alteracoes? (S/N): "RESET);
                            scanf(" %c",&ativar);
                            while (getchar() != '\n');
                            ativar = tolower(ativar);
                            if ((ativar != 's') && (ativar != 'n'))
                            {
                                printf(VERMELHO"\nERRO. Insira 's' ou 'n' como foi informado... \n"RESET); 
                            }else{
                                validar = 0;
                            }
                        }
                    if (ativar == 's') {
                        FILE *fin = fopen(FILE_NAME, "r"); 
                        FILE *fout = fopen(TEMP_FILE, "w");
                        int pulando = 0;
                        
                        while(fgets(linha_leitura, 255, fin)) {
                            char tL[110]; 
                            strcpy(tL, linha_leitura); 
                            tL[strcspn(tL, "\n")] = 0;
                            
                            if(strcmp(tL, etiqueta_alvo) == 0) {
                                pulando = 1; 
                                fprintf(fout, "[%s]\nMETA|%s|%s\n", titulo_receita, categoria_receita, tempo_final_preparo);
                                for(int i = 0; i <= limite_de_edicao; i++) {
                                    if(strlen(conteudo_receita[i]) > 0) {
                                        fprintf(fout, "%s\n", conteudo_receita[i]);
                                    }
                                }
                                fprintf(fout, "[TERMINO]\n");
                            }
                            
                            if(!pulando) {
                                fputs(linha_leitura, fout);
                            }
                            
                            if(pulando && strstr(linha_leitura, "[TERMINO]")) {
                                pulando = 0;
                            }
                        }
                        
                        fclose(fin); 
                        fclose(fout); 
                        remove(FILE_NAME); 
                        rename(TEMP_FILE, FILE_NAME);
                        system("cls");
                        cabecalho();
                        printf(VERDE"\nReceita editada com sucesso!"RESET);
                    } else {
                        system("cls");
                        cabecalho();
                        printf(VERMELHO"\nEdição descartada."RESET);
                    }

                    int valido = 1;
                    while (valido == 1) 
                        {
                            printf(NEGRITO"\n\nQuer continuar a editar? (s/n) "RESET);
                            scanf(" %c",&ativados);
                            while (getchar() != '\n');
                            ativados = tolower(ativados);
                            if ((ativados != 's') && (ativados != 'n'))
                            {
                                printf(VERMELHO"\nERRO. Insira 's' ou 'n' como foi informado... \n"RESET); 
                            }else{
                                valido = 0;
                            }
                        }
                    system("cls");
                    cabecalho();
                    }while(ativados != 'n');
                    
                }
                break;
            // ====================================================================
            // 4. EXCLUIR RECEITA
            // ====================================================================
            case 4:
                {   
                    char ativado;
                    do{
                    FILE *f_exc = fopen(FILE_NAME, "r");
                    if (!f_exc) { printf(NEGRITO"\nArquivo vazio."RESET); 
                        getch(); 
                        break; 
                    }
                    char nomes[50][100]; 
                    int total = 0;
                    while (fgets(linha, sizeof(linha), f_exc)) {
                        if (linha[0] == '[' && !strstr(linha, "[TERMINO]")) {
                            char tempN[100]; strcpy(tempN, linha + 1); 
                            tempN[strcspn(tempN, "]\n")] = 0;
                            strcpy(nomes[total++], tempN); 
                            printf(VERMELHO NEGRITO"[%d]" RESET " %s\n", total, nomes[total-1]);
                        }
                    }
                    fclose(f_exc);
                    int esc; 
                    char aceitado;
                    printf(NEGRITO"\nExcluir qual?"RESET""VERMELHO NEGRITO" (0 cancela): "RESET); 
                    scanf("%d", &esc);
                    system("cls");
                    cabecalho();
                    if(esc == 0){
                        break;
                    }
                    while(getchar() != '\n');
                    if (esc > 0 && esc <= total) {
                        int val = 1;
                        do{
                            printf(NEGRITO"\nExcluir '%s'? (S/N): "RESET, nomes[esc-1]);
                            scanf("%c",&aceitado);
                            while (getchar() != '\n');
                            aceitado = tolower(aceitado);

                            if ((aceitado != 's') && (aceitado != 'n'))
                                {
                                    val = 1;
                                    system("cls");
                                    cabecalho();
                                    printf(VERMELHO"\nERRO. Insira 'S' ou 'N' como foi informado... \n"RESET); 
                                }else{
                                    val = 0;
                                }
                            
                        }while(val == 1);
                        if (aceitado == 's') {
                            f_exc = fopen(FILE_NAME, "r"); 
                            FILE *t = fopen(TEMP_FILE, "w");
                            char tag[110]; 
                            sprintf(tag, "[%s]", nomes[esc-1]);
                            int pulando = 0;
                            while(fgets(linha, 255, f_exc)) {
                                char linL[110]; 
                                strcpy(linL, linha); 
                                linL[strcspn(linL, "\n")] = 0;
                                if(strcmp(linL, tag) == 0) pulando = 1;
                                if(!pulando) fputs(linha, t);
                                if(pulando && strstr(linha, "[TERMINO]")) pulando = 0;
                            }
                            fclose(f_exc); 
                            fclose(t); 
                            remove(FILE_NAME); 
                            rename(TEMP_FILE, FILE_NAME);
                            printf(VERDE"\nExcluído com sucesso!"RESET);
                            getch();
                        }else{
                        printf(VERMELHO"\nCancelado exclusão!"RESET);
                        getch();
                        }
                    }
                    
                    system("cls");
                    cabecalho();

                    int valido = 1;
                    while (valido == 1) 
                        {
                            printf(NEGRITO"\nQuer continuar a excluir(apagar)? (s/n) "RESET);
                            scanf(" %c",&ativado);
                            while (getchar() != '\n');
                            ativado = tolower(ativado);
                            if ((ativado != 's') && (ativado != 'n'))
                            {
                                printf(VERMELHO"\nERRO. Insira 's' ou 'n' como foi informado... \n"RESET); 
                            }else{
                                valido = 0;
                            }
                        }
                    system("cls");
                    cabecalho();
                    }while(ativado != 'n');
                    
                }
                break;
            case 5:
                printf(NEGRITO"Ainda não tem nada..."RESET);
                getch();
                break;
            case 0:
                printf(NEGRITO"\nSaindo do sistema..."RESET);
                getch();
                break;
        }
    } while (opcao != 0);

    return 0;
}

